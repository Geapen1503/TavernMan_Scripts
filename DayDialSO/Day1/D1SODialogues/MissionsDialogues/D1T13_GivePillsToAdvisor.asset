  m_Script: {fileID: 11500000, guid: 512a72de08c75cf4e8a8424f7b75a271, type: 3}
  m_Name: D1T13_GivePillsToAdvisor
  m_EditorClassIdentifier: 
  npc: 0
  sequence:
  - dialogueText: You got the box? Good. Hand it over.
    buttonText: Here
  - dialogueText: I'm keeping these. They'll be useful later... when the time is
      right
    buttonText: Useful how?
  - dialogueText: Don't worry about it. You did your part. You're more than a waiter
      now.
    buttonText: What's next?
  - dialogueText: Not now. Get back to the Boss. Finish whatever thing he asked you
      to do.
    buttonText: The inventory...
  - dialogueText: We can't risk to get caught right now. Go. Before he looks this
      way.
    buttonText: I'm going
