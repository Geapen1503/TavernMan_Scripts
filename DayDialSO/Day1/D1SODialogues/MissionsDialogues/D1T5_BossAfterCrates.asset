  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 512a72de08c75cf4e8a8424f7b75a271, type: 3}
  m_Name: D1T5_BossAfterCrates
  m_EditorClassIdentifier: 
  npc: 33
  sequence:
  - dialogueText: Look at you. The crates are in, and you're still in one piece.
    buttonText: I'm done
  - dialogueText: Don't get comfortable. The rum is here, but the vibe is... rotting
    buttonText: Rotting?
  - dialogueText: This Jazz. I've been breathing this horn-blowing smoke for too
      long. My ears are bleeding.
    buttonText: The music?
  - dialogueText: It's stale. Like old bread. I want fire. I want something that
      smells like Latin sweat and bad decisions.
    buttonText: Latin music?
  - dialogueText: Go upstairs. Tell the lady on stage to kill the Jazz. Tell her
      I want some salsa
    buttonText: She'll listen?
  - dialogueText: She'll listen to me, or she can go sing to the sharks. Tell her
      the Boss wants a change of pace.
    buttonText: On my way
  - dialogueText: And TavernMan? If she gives you trouble... remind her who owns
      the stage.
    buttonText: Got it
