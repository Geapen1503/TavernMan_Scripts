MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 512a72de08c75cf4e8a8424f7b75a271, type: 3}
  m_Name: D1T10_AdvisorPillTalk
  m_EditorClassIdentifier: 
  npc: 0
  sequence:
  - dialogueText: Still breathing? Good. Let's talk about those pills I mentioned.
    buttonText: The pills?
  - dialogueText: Small box. Past the palms, left of the tavern. Right on the sand,
      facing the waves.
    buttonText: The beach?
  - dialogueText: Yeah. But you can't just walk out there. Not without a story.
    buttonText: Why not?
  - dialogueText: The Boss. He watch everything. He sees every shadow that moves.
    buttonText: He's watching?
  - dialogueText: Always. You need a reason to be outside. A job. An official errand.
    buttonText: A cover?
  - dialogueText: Exactly. Wait for him to send you out. When you're "working" for
      him... you get the pills for me.
    buttonText: I understand
  - dialogueText: Keep your head down. Grab the box, hide it, and get back before
      the sweat dries.
    buttonText: I'll do it
  - dialogueText: Speaking of the devil... don't look now, but he's waving. He might
      got a task for you
    buttonText: He's waving?
  - dialogueText: Go. See what he wants. We'll talk about my delivery when you're
      under the stars.
    buttonText: Got it
