  m_Script: {fileID: 11500000, guid: 512a72de08c75cf4e8a8424f7b75a271, type: 3}
  m_Name: D1T14_BossTalkAfterThrowingCoffin
  m_EditorClassIdentifier: 
  npc: 33
  sequence:
  - dialogueText: Ah, you're back... Hooraaay. The man returns from the sand.
    buttonText: I'm back
  - dialogueText: And what about our common friend? Did he decide to stay for a swim?
    buttonText: He's deep
  - dialogueText: Deep? Good. The sea has a big stomach, it doesn't mind one more
      secret.
    buttonText: What now?
  - dialogueText: That was the heavy lifting for the night. You've earned some silence.
    buttonText: No jobs?
  - dialogueText: The glasses are full and the drunks are quiet. I've got no use
      for you right now.
    buttonText: So, I'm off?
  - dialogueText: For the moment, yes. Just don't look like a man with a heavy conscience.
    buttonText: I won't
  - dialogueText: Good. Now move. Before I find another reason to use those muscles.
    buttonText: Moving now
