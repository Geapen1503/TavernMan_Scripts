  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 512a72de08c75cf4e8a8424f7b75a271, type: 3}
  m_Name: D1T1_Boss_Dialogue
  m_EditorClassIdentifier: 
  npc: 33
  sequence:
  - dialogueText: I'm telling you, Barman... the sea has a sense of humor.
    buttonText: ...Hello?
  - dialogueText: One day it gives you fish. Next day? It gives you man. Wet, confused...
      still tasting salt.
    buttonText: That's me.
  - dialogueText: Look at him. Perfect timing. You see this, Barman? This is what
      I call delivery.
    buttonText: Delivery?
  - dialogueText: You're my new TavernMan. You serve the clients. You clean the tables.
      You smile when they don't
    buttonText: Where am I?
  - dialogueText: You run the floor. You keep the glasses full. And you do what I
      tell you.
    buttonText: Why me?
  - dialogueText: Some days, that means pouring drinks. Some days... it means something
      else.
    buttonText: ...Like what?
  - dialogueText: You'll see. For now... go serve some beer to those rats in the
      corner.
    buttonText: Which rats?
  - dialogueText: The ones pretending to be businessmen. Then go upstairs... pour
      some liquid courage for those overdressed Scottish drunks.
    buttonText: Anyone else?
  - dialogueText: And that filthy peasant by the red curtains. Selling trash to the
      worker like he owns the place. Make him pay first.
    buttonText: I'm on it.
