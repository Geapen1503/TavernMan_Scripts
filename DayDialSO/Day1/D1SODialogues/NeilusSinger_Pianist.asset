  m_Name: NeilusSinger_Pianist
  m_EditorClassIdentifier: 
  npc: 28
  sequence:
  - dialogueText: How are you holding up, kiddo?
    buttonText: Busy
  - dialogueText: Hah... good. Means you're still standing
    buttonText: I guess so
  - dialogueText: Poor thing's muted. The hammers don't strike anymore.
    buttonText: Why play?
  - dialogueText: Because that's the rule. Music stays. Sound or not.
    buttonText: I see
  - dialogueText: Strings don't sing anymore. But my fingers remember.
    buttonText: Carry on
