  m_Script: {fileID: 11500000, guid: 512a72de08c75cf4e8a8424f7b75a271, type: 3}
  m_Name: D2T5_IndianAfterThrowingCrates
  m_EditorClassIdentifier: 
  npc: 1
  sequence:
  - dialogueText: You look lighter. I suppose the sea is now carrying my cargo?
    buttonText: It's gone
  - dialogueText: Excellent. Efficiency is a rare currency on this island.
    buttonText: Such a waste
  - dialogueText: Waste? No, my friend. It is logistics. The current will deliver
      those crates to my men on the quiet side of the shore.
    buttonText: Smart
  - dialogueText: It avoids... uncomfortable questions at the main dock. Here, take
      this. For your trouble and your silence
    buttonText: Heavy coin
  - dialogueText: Gold has it's own way of grounding a man. Now, return to your duties
      before your absence is noted.
    buttonText: Back to work
  - dialogueText: Good. We never spoke, TavernMan. Remember that.
    buttonText: Forgot already
