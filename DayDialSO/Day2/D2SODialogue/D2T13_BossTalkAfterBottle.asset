  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 512a72de08c75cf4e8a8424f7b75a271, type: 3}
  m_Name: D2T13_BossTalkAfterBottle
  m_EditorClassIdentifier: 
  npc: 33
  sequence:
  - dialogueText: You got it. Good. Get it under the counter, nice and quiet.
    buttonText: It's safe
  - dialogueText: One bottle is a start, but it doesn't fill the hole in my inventory.
      We still have a thief breathing our air.
    buttonText: Still no lead
  - dialogueText: That's the problem. With the scraps of info you brought back, I
      still can't put a face to the name.
    buttonText: Did my best
  - dialogueText: I'm done with the bar work for tonight. But I'm not done with you.
    buttonText: Meaning?
  - dialogueText: Go back out there. Don't ask questions this time, look for the
      cracks.
    buttonText: Investigate?
  - dialogueText: Talk to whoever you think is hiding something. Squeeze them until
      the truth leaks out.
    buttonText: I'll look around
