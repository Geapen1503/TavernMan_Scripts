  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 512a72de08c75cf4e8a8424f7b75a271, type: 3}
  m_Name: D2T11_BossTalkAfterInvestigation
  m_EditorClassIdentifier: 
  npc: 33
  sequence:
  - dialogueText: Nothing? Not a whisper? Not a single lead on who gutted my inventory?
    buttonText: All denied it
  - dialogueText: So nobody knows, ugh? A crate of history doesn't just sprout legs
      and walk into the ocean by itself!
    buttonText: I asked everyone
  - dialogueText: We're in the fog... I need a moment. Let me think, let me think...
    buttonText: What now?
  - dialogueText: Don't just stand there! Keep the floor moving. Serve the cheap
      rum.
    buttonText: To who?
  - dialogueText: To that mountain of a man from the pyramids. To the guy in the
      dirty overalls, too.
    buttonText: And the others?
  - dialogueText: The Japanese pair as well. If I'm losing money, they're losing
      quality
    buttonText: Cheap rum?
  - dialogueText: Every last drop! Go! I need to figure out who's lying to my face.
    buttonText: I'm going
