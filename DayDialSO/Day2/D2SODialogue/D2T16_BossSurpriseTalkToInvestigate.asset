  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 512a72de08c75cf4e8a8424f7b75a271, type: 3}
  m_Name: D2T16_BossSurpriseTalkToInvestigate
  m_EditorClassIdentifier: 
  npc: 33
  sequence:
  - dialogueText: I saw you whispering with the Indian and the Suit. You pinning
      my missing bottles on them?
    buttonText: They wanted food
  - dialogueText: A meal? Tell them the kitchen is dead tonight. They can starve
      for all I care.
    buttonText: I'll tell them
  - dialogueText: Just stay alert. I want that thief's head on a plate, and I want
      it soon.
    buttonText: It's tough
  - dialogueText: Tough? Ha! A petty thief is nothing. Ever face a Titan Triggerfish?
    buttonText: A what?
  - dialogueText: Pure muscle and teeth. I took one down with my bare hands years
      ago. Put its head on a silver platter.
    buttonText: Bare hands?
  - dialogueText: That's right. If I can gut a monster like that, a simple rat won't
      last long.
    buttonText: I'm sure
  - dialogueText: Your shift is really over now. Get out of here. But don't think
      I've stopped looking
    buttonText: Going now
