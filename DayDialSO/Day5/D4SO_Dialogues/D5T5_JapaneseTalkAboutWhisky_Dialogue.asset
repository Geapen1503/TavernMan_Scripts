  m_Script: {fileID: 11500000, guid: 512a72de08c75cf4e8a8424f7b75a271, type: 3}
  m_Name: D5T5_JapaneseTalkAboutWhisky_Dialogue
  m_EditorClassIdentifier: 
  npc: 3
  sequence:
  - dialogueText: You are in the way. Leave.
    buttonText: Boss sent me
  - dialogueText: We do not discuss business with staff.
    buttonText: Seabed whisky
  - dialogueText: Two crates of seabed whisky? We can provide this.
    buttonText: When?
  - dialogueText: Next night. At the shore.
    buttonText: The cost?
  - dialogueText: Double the usual price. In gold.
    buttonText: It's expensive
  - dialogueText: Quality is not cheap. Do not be late with the payment.
    buttonText: I won't
  - dialogueText: We are finished.
    buttonText: Indeed
