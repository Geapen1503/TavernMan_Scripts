MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 512a72de08c75cf4e8a8424f7b75a271, type: 3}
  m_Name: D5T1_BossDayIntoTalk_Dialogue
  m_EditorClassIdentifier: 
  npc: 33
  sequence:
  - dialogueText: Look who's back. Still chasing that royal flush, are we?
    buttonText: Poker time?
  - dialogueText: The cards can wait. Your debt is a permanent resident here, and
      it's getting comfortable.
    buttonText: I'll pay
  - dialogueText: You'll work. I'm done watching you play waiter with those clumsy
      fingers.
    buttonText: What work?
  - dialogueText: Grab that mop. I want every floorboard to glisten like a whale's
      back
    buttonText: Whole place?
  - dialogueText: Upstairs, downstairs, everywhere. If I see a speck of dust, I'll
      use your shirt.
    buttonText: Why the rush?
  - dialogueText: High-shelf drinkers are dropping anchor tomorrow. People with big
      wallets and short tempers.
    buttonText: Who's coming?
  - dialogueText: The kind of people who don't like sand in their soup. Make it shine,
      TavernMan.
    buttonText: I'm on it
  - dialogueText: Good. If I can't see my reflection in the wood, you're sleeping
      with the starfish.
    buttonText: I'm moving
