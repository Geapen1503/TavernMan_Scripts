  m_Script: {fileID: 11500000, guid: 512a72de08c75cf4e8a8424f7b75a271, type: 3}
  m_Name: D4T14_PokerTalkAfterThreeLoss_Dialogue
  m_EditorClassIdentifier: 
  npc: 22
  sequence:
  - dialogueText: Leaving so soon? We were just getting to the interesting part.
      Four is a lucky number in some cultures.
    buttonText: It's rigged
  - dialogueText: Careful there. Accusations are for people who can't handle their
      own bad luck. One more?
    buttonText: I'm done
  - dialogueText: I was starting to enjoy the company... and your coins.
    buttonText: I'm out
