MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 512a72de08c75cf4e8a8424f7b75a271, type: 3}
  m_Name: D4T17_IndianAfterPokerLosses_Dialogue
  m_EditorClassIdentifier: 
  npc: 1
  sequence:
  - dialogueText: Bad news has wings, my friend. I heard the poker table was... unkind
      to you tonight.
    buttonText: How do you know
  - dialogueText: A man like me always knows where the info is. Especially in a place
      this small.
    buttonText: It's over
  - dialogueText: For him, perhaps. But for us? Our books are still open. Are you
      ready to collect your payment?
    buttonText: Now
  - dialogueText: Perfect! But I don't deal in heavy gold tonight. Too much attention.
    buttonText: What?
  - dialogueText: Your compensation is... an investment in your future. A special
      item
    buttonText: An item?
  - dialogueText: One that could be very handy for someone in your precarious position.
      I've kept it safe, away from prying eyes.
    buttonText: Where?
  - dialogueText: Outside, in the sand. You'll see a cross marked near the shore.
      Consider it a little treasure hunt.
    buttonText: Digging?
  - dialogueText: It's buried under. Dig until you find something that doesn't feel
      like sand. It's yours. We'll be even then.
    buttonText: Hope so
