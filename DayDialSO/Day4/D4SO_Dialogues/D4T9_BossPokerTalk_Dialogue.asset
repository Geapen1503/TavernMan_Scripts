  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 512a72de08c75cf4e8a8424f7b75a271, type: 3}
  m_Name: D4T9_BossPokerTalk_Dialogue
  m_EditorClassIdentifier: 
  npc: 33
  sequence:
  - dialogueText: Look at that... my favorite mop-handler actually has a sense of
      timing. You're just in time for the main event.
    buttonText: Poker?
  - dialogueText: Poker. The table's waiting upstairs, and the seats are getting
      warm. It's time you finally earned your keep for real.
    buttonText: My keep...
  - dialogueText: Every cent of it. I want that ledger to bleed green again. You're
      going to win back everything.
    buttonText: High stakes
  - dialogueText: The highest. Go up there and clean those porpoise out until they're
      begging for air. I want every coin they brought to this rock.
    buttonText: If I lose?
  - dialogueText: We don't talk about "if". That word doesn't exist tonight.
    buttonText: ...
  - dialogueText: You're going to win because the alternative involves a very long
      walk off a very short dock.
    buttonText: Understood
  - dialogueText: Then move. Don't let the cards get cold while you're standing there
      counting your toes.
    buttonText: Going up
