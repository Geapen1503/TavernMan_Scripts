  m_Script: {fileID: 11500000, guid: 512a72de08c75cf4e8a8424f7b75a271, type: 3}
  m_Name: D4T16_LadyAfterPokerLosses_Dialogue
  m_EditorClassIdentifier: 
  npc: 36
  sequence:
  - dialogueText: '"Wait here." Sure, I''ll just go for a stroll in the woods then.
      Dumbass... Oh, you''re here?'
    buttonText: Four times
  - dialogueText: You lost four times? I told you not to go up there.
    buttonText: For the disks
  - dialogueText: The disks? You're losing all that money for some latin records?
    buttonText: It's rigged
  - dialogueText: Obviously. Nobody ever wins at that table.
    buttonText: I thought...
  - dialogueText: Well, you tried. And now you're broke.
    buttonText: I am
  - dialogueText: Besides... have you heard about that thing called Bitcoin?
    buttonText: What the hell?
  - dialogueText: Forget it... You're running around and I'm stuck on this stool.
      Do you actually think a few songs will change that?
    buttonText: I don't know
  - dialogueText: I don't know either. I just know that game is a waste of time
    buttonText: Maybe
  - dialogueText: No maybe about it. Just another night of staring at the floorboards
      while the Boss counts your mistakes.
    buttonText: Yeah
  - dialogueText: I'm still here. You're still there. Nothing really moves.
    buttonText: That's true
