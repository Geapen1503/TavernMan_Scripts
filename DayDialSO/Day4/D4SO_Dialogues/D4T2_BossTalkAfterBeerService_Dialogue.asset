  m_Script: {fileID: 11500000, guid: 512a72de08c75cf4e8a8424f7b75a271, type: 3}
  m_Name: D4T2_BossTalkAfterBeerService_Dialogue
  m_EditorClassIdentifier: 
  npc: 33
  sequence:
  - dialogueText: Done already? I hope the beer was bitter enough to keep them paying.
    buttonText: All served
  - dialogueText: Good. Let the poison sink in until their pockets start feeling
      too heavy for their own good.
    buttonText: Anything else?
  - dialogueText: Not for the moment. Go merge with the scenery or count the palm
      trees until you're dizzy.
    buttonText: And then?
  - dialogueText: And then wait. I'll give you a shout once my head cooks up a new
      way to ruin your peace.
    buttonText: Fine
  - dialogueText: Don't drift too far. I'm not in the mood for a scavenger hunt when
      the real work starts.
    buttonText: Understood
