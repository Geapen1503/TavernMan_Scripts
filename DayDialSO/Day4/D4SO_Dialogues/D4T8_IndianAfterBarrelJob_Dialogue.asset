  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 512a72de08c75cf4e8a8424f7b75a271, type: 3}
  m_Name: D4T8_IndianAfterBarrelJob_Dialogue
  m_EditorClassIdentifier: 
  npc: 1
  sequence:
  - dialogueText: The deck looks a little more full. I assume the delivery was successful?
    buttonText: Done.
  - dialogueText: Excellent. Reliability is the cornerstone of any partnership. Your
      compensation is ready and waiting.
    buttonText: Where?
  - dialogueText: Patience, my friend. Before you collect your bonus, we need to
      ensure our safety.
    buttonText: Safety?
  - dialogueText: You go see the Boss first. Ensure his hands are empty and his eyes
      are focused elsewhere.
    buttonText: Why now?
  - dialogueText: It is best to finalize our transaction when he isn't looking at
      you.
    buttonText: Looking?
  - dialogueText: If he has no more chores for you, you can disappear for a moment
      without raising suspicion.
    buttonText: Discreet
  - dialogueText: Yes, my friend. Confirm your schedule with him, then return to
      me. We'll settle the books then.
    buttonText: Fine
