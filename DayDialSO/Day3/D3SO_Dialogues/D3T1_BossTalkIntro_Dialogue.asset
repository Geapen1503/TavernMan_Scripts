  m_Script: {fileID: 11500000, guid: 512a72de08c75cf4e8a8424f7b75a271, type: 3}
  m_Name: D3T1_BossTalkIntro_Dialogue
  m_EditorClassIdentifier: 
  npc: 33
  sequence:
  - dialogueText: Ahhhh, another fresh night under the stars, and another itch in
      my brain.
    buttonText: Ready?
  - dialogueText: Ready for what? To be robbed again? I'm still chewing on that missing
      crate
    buttonText: It's gone
  - dialogueText: For now. But my thoughts are tangling like old fishing lines. I
      need to clear the mess.
    buttonText: How?
  - dialogueText: Pour me a whiskey. I need something to cut through this fog.
    buttonText: To think?
  - dialogueText: Exactly. I can't catch a rat while my head is spinning in circles.
      I need to get my bearings.
    buttonText: I'll pour
  - dialogueText: Do that. Maybe the bottle has more answers than the people in this
      room.
    buttonText: Coming up
