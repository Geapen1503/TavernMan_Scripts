MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 512a72de08c75cf4e8a8424f7b75a271, type: 3}
  m_Name: D3T9_WongGunTalk_Dialogue
  m_EditorClassIdentifier: 
  npc: 3
  sequence:
  - dialogueText: The meal earlier. It was... adequate.
    buttonText: Glad you liked it
  - dialogueText: We have noted your diligence. You move through this tavern without
      causing unnecessary ripples.
    buttonText: I'm efficient
  - dialogueText: Efficiency is respected. We require a small service. A quick assignment,
      outside your usual duties.
    buttonText: The pay?
  - dialogueText: Respect. A rare and vital commodity in a place like this.
    buttonText: Just respect?
  - dialogueText: Respect leads to opportunities that gold cannot buy. It ensures
      a longer life.
    buttonText: Whatever
  - dialogueText: This handgun. Take it. It must be gone.
    buttonText: Get rid of it?
  - dialogueText: Into the deep water. Far from this shore.
    buttonText: I'll do it
  - dialogueText: Go then. We will see if you are truly as efficient as you claim.
    buttonText: We'll see
