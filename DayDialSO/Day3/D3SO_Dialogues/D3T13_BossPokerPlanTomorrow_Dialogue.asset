  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 512a72de08c75cf4e8a8424f7b75a271, type: 3}
  m_Name: D3T13_BossPokerPlanTomorrow_Dialogue
  m_EditorClassIdentifier: 
  npc: 33
  sequence:
  - dialogueText: 'It''s about time. Now listen: tomorrow, you''re going back to
      that poker table.'
    buttonText: Why?
  - dialogueText: You're going to win back every cent you pissed away tonight.
    buttonText: I'll try
  - dialogueText: You'd better do more than try. Practice your shuffle. We can't
      afford to lose twice.
    buttonText: I need luck
  - dialogueText: Then I hope you have the luck of a goldfish tomorrow.
    buttonText: A goldfish?
  - dialogueText: Don't give me that look. It's one of the luckiest fish in the world,
      right up there with the Koi carps.
    buttonText: Luckiest?
  - dialogueText: They can survive in a bowl or a pond, they just keep swimming.
    buttonText: If you say so
  - dialogueText: I do say so. Now get out of my sight. This night shift is over.
    buttonText: Finally
